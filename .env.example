# OpenAI-compatible API (LM Studio, Ollama OpenAI plugin, vLLM, OpenAI, etc.)
LM_BASE_URL=http://127.0.0.1:1234/v1
LM_API_KEY=lm-studio
LM_MODEL=qwen2.5-7b-instruct

# Optional: retries when the model returns non-JSON
# LM_JSON_RETRIES=2

# Optional: max_tokens for sub-agent free-form completions (omit if your server errors on unknown params)
# LM_CHAT_MAX_TOKENS=400

# Optional: use an existing Chrome/Chromium instead of Playwright-managed binaries
# BROWSER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# CHROMIUM_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Observation size limits (context / token budget)
# OBS_TEXT_CHAR_LIMIT=9000
# OBS_STRUCTURE_JSON_LIMIT=2500
